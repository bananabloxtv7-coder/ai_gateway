{
  "_comment": "Legacy format — kept for Docker reference only. The gateway now uses providers.json + env vars.",
  "providers": [
    {
      "name": "Alibaba",
      "slug": "alibaba",
      "enabled": true,
      "base_url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
      "keys_env": "ALIBABA_API_KEYS",
      "models": ["qwen-max", "qwen-plus"]
    },
    {
      "name": "NVIDIA",
      "slug": "nvidia",
      "enabled": true,
      "base_url": "https://integrate.api.nvidia.com/v1",
      "keys_env": "NVIDIA_API_KEYS",
      "models": ["meta/llama-3.3-70b-instruct"]
    },
    {
      "name": "flatkey.ai",
      "slug": "flatkey",
      "enabled": true,
      "base_url": "https://router.flatkey.ai/v1",
      "keys_env": "FLATKEY_API_KEYS",
      "models": ["claude-sonnet-4-5", "gpt-5.4"]
    },
    {
      "name": "cometapi",
      "slug": "cometapi",
      "enabled": true,
      "base_url": "https://api.cometapi.com/v1",
      "keys_env": "COMETAPI_API_KEYS",
      "models": ["claude-sonnet-4-5", "gpt-5.4", "gemini-2.5-pro"]
    }
  ]
}
